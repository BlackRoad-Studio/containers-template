# ─────────────────────────────────────────────────────────────────────────────
# BlackRoad OS, Inc. – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=848cf0b18d51e0170e0d1537aec3505a

# Cloudflare KV – create with `wrangler kv namespace create <NAME>`
SESSIONS_KV_NAMESPACE_ID=
SESSIONS_KV_NAMESPACE_PREVIEW_ID=
API_KEYS_KV_NAMESPACE_ID=
API_KEYS_KV_NAMESPACE_PREVIEW_ID=

# Auth – set via `wrangler secret put JWT_SECRET`
JWT_SECRET=

# Railway
RAILWAY_TOKEN=

# Vercel
VERCEL_TOKEN=

# Stripe – set STRIPE_WEBHOOK_SECRET via `wrangler secret put STRIPE_WEBHOOK_SECRET`
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Clerk (identity provider for OAuth callbacks)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Database
DATABASE_URL=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Service Mesh
SERVICE_REGISTRY_URL=https://api.blackroad.io/registry
SERVICE_NAME=containers-template
SERVICE_ORG=BlackRoad-OS
